@startuml

actor Client
participant "Interface UI" as UI
participant "CatalogueController" as CC
participant "CatalogueService" as CS
participant "ProduitRepository" as PR

Client -> UI : saisir mot-clé recherche
UI -> CC : rechercherProduit(motCle)
CC -> CS : chercherProduits(motCle)
CS -> PR : findByNom(motCle)
PR --> CS : liste produits trouvés
CS --> CC : résultats
CC --> UI : afficher résultats
UI --> Client : produits affichés

@enduml