@startuml

class Utilisateur {
  - id : int
  - nom : String
  - email : String
  - motDePasse : String
  + sAuthentifier()
  + sInscrire()
}

class Client {
  + consulterCatalogue()
  + rechercherProduit()
  + passerCommande()
}

class Agriculteur {
  + ajouterProduit()
  + modifierProduit()
  + supprimerProduit()
}

class Admin {
  + gererUtilisateurs()
  + consulterStatistiques()
}

class Produit {
  - idProduit : int
  - nom : String
  - prix : double
  - quantite : int
  + getIdProduit() : int
  + getNom() : String
  + setNom(String)
  + getPrix() : double
  + setPrix(double)
  + getQuantite() : int
  + setQuantite(int)
}

class Commande {
  - idCommande : int
  - date : LocalDate
  - total : double
  + calculerTotal()
  + ajouterLigne(LigneCommande)
}

class LigneCommande {
  - produit : Produit
  - quantite : int
  + getTotal() : double
}

class Catalogue {
  - produits : List<Produit>
  + ajouterProduit(Produit)
  + supprimerProduit(Produit)
  + afficherCatalogue()
  + rechercherProduit(String)
  + rechercherParPrixMin(double) : List<Produit>
  + rechercherParPrixMax(double) : List<Produit>
  + rechercherParPlage(double, double) : List<Produit>
  + rechercherParQuantiteMin(int) : List<Produit>
  + obtenirTousProduits() : List<Produit>
  + nombreDeProduits() : int
}

class GestionProduitsEtCatalogue {
  - catalogue : Catalogue
  + ajouterProduit(Produit)
  + supprimerProduit(Produit)
  + modifierNomProduit(Produit, String)
  + modifierPrixProduit(Produit, double)
  + modifierQuantiteProduit(Produit, int)
  + modifierProduit(Produit, String, double, int)
}

class Livraison {
  - statut : String
  + mettreAJourStatut(String)
}

' Héritage
Utilisateur <|-- Client : hérite
Utilisateur <|-- Agriculteur : hérite
Utilisateur <|-- Admin : hérite

' Relations
Client "1" -- "0..*" Commande : passe
Commande "1" -- "1.." LigneCommande : contient
LigneCommande --> Produit : concerne
Agriculteur "1" -- "0..*" Produit : gère
Catalogue o-- Produit : contient
Admin -- Utilisateur : gère
Commande -- Livraison : possède
GestionProduitsEtCatalogue --> Catalogue : utilise
Utilisateur --> Catalogue : consulte
Agriculteur --> GestionProduitsEtCatalogue : utilise

' Répartition des membres
note top of Utilisateur
Ahlem
US1 Inscription
US2 Connexion
end note

note top of Produit
Melak
US3 Ajouter produit
US4 Modifier/Supprimer
end note

note top of Catalogue
Rahma
US5 Catalogue
US6 Recherche
end note

note top of Commande
Rihab
US7 Commande
US8 Livraison
end note

note top of Admin
Wael
US9 Gestion utilisateurs
US10 Statistiques
end note

note top of GestionProduitsEtCatalogue
Nouvelle classe
Gestion CRUD produits
end note

@enduml